PORT=10000
NODE_ENV=development
JWT_SECRET=gestion_vente_secret_key

# ============================================================
# CONFIGURATION SMTP (envoi d'emails réels)
# ============================================================
# ⚠️ Render bloque le port 25 sortant : impossible d'auto-héberger
# un serveur SMTP. Utilisez OBLIGATOIREMENT un relai SMTP externe
# (port 587 STARTTLS ou 465 SSL). Exemples ci-dessous.
#
# --- Option 1 : Gmail (le plus simple pour tester) ---
# 1. Activez la validation en 2 étapes sur votre compte Google
# 2. Créez un "Mot de passe d'application" : https://myaccount.google.com/apppasswords
# 3. Remplissez :
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre.compte@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxx   # le mot de passe d'application (16 car.)
#
# --- Option 2 : Brevo (ex-Sendinblue, 300 emails/j gratuits) ---
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=xxxxxxx@smtp-brevo.com
# SMTP_PASS=xxxxxxxxxxxxxxxx
#
# --- Option 3 : SendGrid (100 emails/j gratuits) ---
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxxx
#
# --- Adresse expéditeur affichée ---
SMTP_FROM=nepasrepondre@server-gestion-ventes.onrender.com
SMTP_FROM_NAME=Ne pas répondre

# Remplissez ces 4 lignes puis relancez le serveur (npm start).
# Sur Render : ajoutez ces variables dans Dashboard → Environment.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
